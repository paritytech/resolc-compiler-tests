{
  "$schema": "../../../../schema.json",
  "modes": [
    "Y Mz S+",
    "Y Ms S+",
    "Y Mz S-",
    "Y Ms S-"
  ],
  "cases": [
    {
      "name": "ERC20 Transfers",
      "comment": "Benchmarks ERC20 transfers by minting tokens on one account and then sending them to another account. Minting can be done by anybody and therefore it doesn't require a specific minter account.",
      "inputs": [
        {
          "comment": "Deploying the ERC20 Contract to be used in the workload",
          "instance": "ERC20",
          "method": "#deployer",
          "calldata": [
            "0x40",
            "0x80",
            "4",
            "0x5742544300000000000000000000000000000000000000000000000000000000",
            "14",
            "0x5772617070656420425443000000000000000000000000000000000000000000"
          ],
          "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf"
        },
        {
          "comment": "The primary benchmark steps and repetition",
          "start_watcher": true,
          "repeat": 40000,
          "steps": [
            {
              "comment": "Allocating an account for the sender",
              "allocate_account": "$VARIABLE:SENDER_ACCOUNT"
            },
            {
              "comment": "Mint tokens to the sender's account",
              "instance": "ERC20",
              "method": "mint",
              "caller": "$VARIABLE:SENDER_ACCOUNT",
              "calldata": [
                "$VARIABLE:SENDER_ACCOUNT",
                "10000000000000000000000000"
              ]
            },
            {
              "comment": "Sending tokens to the receiver",
              "repeat": 3,
              "steps": [
                {
                  "comment": "Sending tokens to the receiver's account",
                  "instance": "ERC20",
                  "method": "transfer",
                  "caller": "$VARIABLE:SENDER_ACCOUNT",
                  "calldata": [
                    "0x0000000000000000000000000000000000000001",
                    "1"
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "contracts": {
    "ERC20": "main.sol:ERC20"
  }
}