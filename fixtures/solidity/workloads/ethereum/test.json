{
  "$schema": "../../../../schema.json",
  "modes": [
    "Y Ms S-"
  ],
  "cases": [
    {
      "name": "WETH Transactions",
      "comment": "Benchmarks WETH deposit/transfer cycle. Each iteration deposits ETH to wrap it, then transfers WETH tokens.",
      "inputs": [
        {
          "comment": "Deploying the WETH Contract to be used in the workload",
          "instance": "WETH",
          "method": "#deployer",
          "calldata": [],
          "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf"
        },
        {
          "comment": "The primary benchmark steps and repetition",
          "start_watcher": true,
          "repeat": 5,
          "steps": [
            {
              "comment": "Allocating an account for the sender",
              "allocate_account": "$VARIABLE:SENDER_ACCOUNT"
            },
            {
              "comment": "Deposit ETH to wrap it into WETH",
              "instance": "WETH",
              "method": "deposit",
              "caller": "$VARIABLE:SENDER_ACCOUNT",
              "calldata": [],
              "value": "10000000000000000000 wei"
            },
            {
              "comment": "Sending WETH tokens to the receiver",
              "repeat": 3,
              "steps": [
                {
                  "comment": "Transferring WETH to the receiver's account",
                  "instance": "WETH",
                  "method": "transfer",
                  "caller": "$VARIABLE:SENDER_ACCOUNT",
                  "calldata": [
                    "0x0000000000000000000000000000000000000001",
                    "1"
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Tether Transactions",
      "comment": "Benchmarks TetherToken transfer and approve+transferFrom flows using pre-funded helper contracts. Helpers are minted tokens in setup, then the benchmark loop only does transfers — no minting during measurement, no cross-sender dependencies.",
      "inputs": [
        {
          "comment": "Deploy TetherToken(100000000000, 'Tether USD', 'USDT', 6).",
          "instance": "TetherToken",
          "method": "#deployer",
          "calldata": "",
          "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf"
        },
        {
          "comment": "Deploy TetherBenchmark helper",
          "instance": "TetherBenchmark",
          "method": "#deployer",
          "calldata": [
            "TetherToken.address"
          ],
          "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf"
        },
        {
          "comment": "Transfer 50,000 USDT from deployer to TetherBenchmark for direct transfers",
          "instance": "TetherToken",
          "method": "transfer",
          "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf",
          "calldata": [
            "TetherBenchmark.address",
            "50000000000"
          ]
        },
        {
          "comment": "Deployer approves TetherBenchmark to pull up to 50,000 USDT from deployer's balance. Exercises the real approve path: deployer=holder, TetherBenchmark=spender.",
          "instance": "TetherToken",
          "method": "approve",
          "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf",
          "calldata": [
            "TetherBenchmark.address",
            "50000000000"
          ]
        },
        {
          "comment": "Benchmark loop — transfer uses TetherBenchmark's own balance, transferFrom pulls from deployer's pre-approved balance. Real two-party approve/transferFrom flow.",
          "start_watcher": true,
          "repeat": 5,
          "steps": [
            {
              "comment": "Allocate a sender account",
              "allocate_account": "$VARIABLE:SENDER"
            },
            {
              "comment": "Approve 0x1 address",
              "instance": "TetherToken",
              "method": "approve",
              "caller": "$VARIABLE:SENDER",
              "calldata": [
                "0x0000000000000000000000000000000000000001",
                "500"
              ],
              "gas_overrides": {
                "zombienet-polkavm-resolc": { "gas_limit": 10000 },
                "zombienet-revm-solc": { "gas_limit": 10000 }
              }
            },
            {
              "comment": "Transfer 500 USDT from TetherBenchmark's balance to a recipient",
              "instance": "TetherBenchmark",
              "method": "transfer",
              "caller": "$VARIABLE:SENDER",
              "calldata": [
                "0x0000000000000000000000000000000000000001",
                "500000000"
              ],
              "gas_overrides": {
                "zombienet-polkavm-resolc": { "gas_limit": 10000 },
                "zombienet-revm-solc": { "gas_limit": 10000 }
              }
            },
            {
              "comment": "Pull 300 USDT from deployer via transferFrom (deployer approved TetherBenchmark in setup)",
              "instance": "TetherBenchmark",
              "method": "transferFrom",
              "caller": "$VARIABLE:SENDER",
              "calldata": [
                "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf",
                "0x0000000000000000000000000000000000000002",
                "300000000"
              ],
              "gas_overrides": {
                "zombienet-polkavm-resolc": { "gas_limit": 10000 },
                "zombienet-revm-solc": { "gas_limit": 10000 }
              }
            },
            {
              "comment": "Multiple small transfers from TetherBenchmark's balance",
              "repeat": 3,
              "steps": [
                {
                  "comment": "Transfer 50 USDT to a merchant",
                  "instance": "TetherBenchmark",
                  "method": "transfer",
                  "caller": "$VARIABLE:SENDER",
                  "calldata": [
                    "0x0000000000000000000000000000000000000003",
                    "50000000"
                  ],
                  "gas_overrides": {
                    "zombienet-polkavm-resolc": { "gas_limit": 10000 },
                    "zombienet-revm-solc": { "gas_limit": 10000 }
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "XEN Minter Transactions",
      "comment": "Simulates batch XEN minting via CoinTool: deploys XENCrypto and CoinTool_Benchmark (inherits CoinTool_App), then repeatedly batch-creates CREATE2 proxies that each delegatecall claimRank on XENCrypto. Matches the t(2, d(XENCrypto, claimRank(70)), 0x01) pattern from the reference benchmark.",
      "inputs": [
        {
          "comment": "Deploy XENCrypto \u2014 constructor records block.timestamp as genesisTs",
          "instance": "XENCrypto",
          "method": "#deployer",
          "calldata": [],
          "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf"
        },
        {
          "comment": "Deploy CoinTool_Benchmark (inherits CoinTool_App, adds batchClaimRank convenience function)",
          "instance": "CoinTool_Benchmark",
          "method": "#deployer",
          "calldata": [],
          "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf"
        },
        {
          "comment": "Benchmark loop \u2014 each iteration batch-creates 2 CREATE2 proxies that each call claimRank(70) on XENCrypto via delegatecall",
          "start_watcher": true,
          "repeat": 5,
          "steps": [
            {
              "comment": "Batch create 2 proxies, each delegatecalls d(XENCrypto, claimRank(70))",
              "instance": "CoinTool_Benchmark",
              "method": "batchClaimRank(address,uint256,uint256)",
              "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf",
              "calldata": [
                "XENCrypto.address",
                "2",
                "70"
              ]
            }
          ]
        }
      ]
    }
  ],
  "contracts": {
    "WETH": "weth.sol:WETH9",
    "TetherToken": "tether.sol:TetherToken",
    "TetherBenchmark": "tether.sol:TetherBenchmark",
    "XENMath": "xen/xen_token.sol:XENMath",
    "XENCrypto": "xen/xen_token.sol:XENCrypto",
    "CoinTool_Proxy": "xen/xen_minter.sol:CoinTool_Proxy",
    "CoinTool_App": "xen/xen_minter.sol:CoinTool_App",
    "CoinTool_Benchmark": "xen/xen_minter.sol:CoinTool_Benchmark"
  },
  "libraries": {
    "xen/xen_token.sol": {
      "XENMath": "XENMath"
    }
  }
}
