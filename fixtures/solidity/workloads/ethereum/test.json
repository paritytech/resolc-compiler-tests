{
  "$schema": "../../../../schema.json",
  "modes": [
    "Y Mz S+",
    "Y Ms S+",
    "Y Mz S-",
    "Y Ms S-"
  ],
  "cases": [
    {
      "name": "WETH Transactions",
      "comment": "Benchmarks WETH deposit/transfer cycle. Each iteration deposits ETH to wrap it, then transfers WETH tokens.",
      "inputs": [
        {
          "comment": "Deploying the WETH Contract to be used in the workload",
          "instance": "WETH",
          "method": "#deployer",
          "calldata": [],
          "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf"
        },
        {
          "comment": "The primary benchmark steps and repetition",
          "start_watcher": true,
          "repeat": 5,
          "steps": [
            {
              "comment": "Allocating an account for the sender",
              "allocate_account": "$VARIABLE:SENDER_ACCOUNT"
            },
            {
              "comment": "Deposit ETH to wrap it into WETH",
              "instance": "WETH",
              "method": "deposit",
              "caller": "$VARIABLE:SENDER_ACCOUNT",
              "calldata": [],
              "value": "10000000000000000000 wei"
            },
            {
              "comment": "Sending WETH tokens to the receiver",
              "repeat": 3,
              "steps": [
                {
                  "comment": "Transferring WETH to the receiver's account",
                  "instance": "WETH",
                  "method": "transfer",
                  "caller": "$VARIABLE:SENDER_ACCOUNT",
                  "calldata": [
                    "0x0000000000000000000000000000000000000001",
                    "1"
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Tether Transactions",
      "comment": "Simulates realistic USDT activity. Each sender mints tokens directly (no cross-contract calls), then does transfers and approvals — all from the sender's own nonce sequence.",
      "inputs": [
        {
          "comment": "Deploy TetherToken(100000000000, 'Tether USD', 'USDT', 6).",
          "instance": "TetherToken",
          "method": "#deployer",
          "calldata": "",
          "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf"
        },
        {
          "comment": "Benchmark loop — each sender mints tokens. Isolated to debug Asset Hub gas estimation.",
          "start_watcher": true,
          "repeat": 5,
          "steps": [
            {
              "comment": "Allocate a sender account",
              "allocate_account": "$VARIABLE:SENDER"
            },
            {
              "comment": "Sender mints 2000 USDT to themselves",
              "instance": "TetherToken",
              "method": "mint",
              "caller": "$VARIABLE:SENDER",
              "calldata": [
                "$VARIABLE:SENDER",
                "2000000000"
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "XEN Minter Transactions",
      "comment": "Simulates batch XEN minting via CoinTool: deploys XENCrypto and CoinTool_Benchmark (inherits CoinTool_App), then repeatedly batch-creates CREATE2 proxies that each delegatecall claimRank on XENCrypto. Matches the t(2, d(XENCrypto, claimRank(70)), 0x01) pattern from the reference benchmark.",
      "inputs": [
        {
          "comment": "Deploy XENCrypto \u2014 constructor records block.timestamp as genesisTs",
          "instance": "XENCrypto",
          "method": "#deployer",
          "calldata": [],
          "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf"
        },
        {
          "comment": "Deploy CoinTool_Benchmark (inherits CoinTool_App, adds batchClaimRank convenience function)",
          "instance": "CoinTool_Benchmark",
          "method": "#deployer",
          "calldata": [],
          "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf"
        },
        {
          "comment": "Benchmark loop \u2014 each iteration batch-creates 2 CREATE2 proxies that each call claimRank(70) on XENCrypto via delegatecall",
          "start_watcher": true,
          "repeat": 5,
          "steps": [
            {
              "comment": "Batch create 2 proxies, each delegatecalls d(XENCrypto, claimRank(70))",
              "instance": "CoinTool_Benchmark",
              "method": "batchClaimRank(address,uint256,uint256)",
              "caller": "0x7e5f4552091a69125d5dfcb7b8c2659029395bdf",
              "calldata": [
                "XENCrypto.address",
                "2",
                "70"
              ]
            }
          ]
        }
      ]
    }
  ],
  "contracts": {
    "WETH": "weth.sol:WETH9",
    "TetherToken": "tether.sol:TetherToken",
    "XENMath": "xen/xen_token.sol:XENMath",
    "XENCrypto": "xen/xen_token.sol:XENCrypto",
    "CoinTool_Proxy": "xen/xen_minter.sol:CoinTool_Proxy",
    "CoinTool_App": "xen/xen_minter.sol:CoinTool_App",
    "CoinTool_Benchmark": "xen/xen_minter.sol:CoinTool_Benchmark"
  },
  "libraries": {
    "xen/xen_token.sol": {
      "XENMath": "XENMath"
    }
  }
}
