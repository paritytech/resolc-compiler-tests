{
  "$schema": "../../../../schema.json",
  "modes": [
    "Y Mz S+",
    "Y Ms S+"
  ],
  "cases": [
    {
      "name": "Festival smoke",
      "comment": "Realistic festival workload exercising nested repeat blocks and variable-name composition with multiple inner $VARIABLE: refs. Setup deploys contracts and wires authorisation; no pre-watcher attendee onboarding is needed because event-day uses cross-pool peer verifies (PRE verifies NEW, NEW verifies PRE) which avoids self-collision without anchor POAPs. Three measured phases: 4 attendee-initiated register() calls, 2 combined-door outer iters (4 checkIns + 2 manualCheckIns), and 6 createSessions plus 12 cross-pool verifies.",
      "inputs": [
        {
          "allocate_account": "$VARIABLE:DEPLOYER",
          "comment": "DEPLOYER (key 1) deploys all contracts and holds all roles (DEFAULT_ADMIN_ROLE / MANAGER_ROLE / VOLUNTEER_ROLE) from the Festival constructor."
        },
        {
          "allocate_account": "$VARIABLE:VOLUNTEER_0",
          "comment": "Two volunteer accounts split the door-side nonce streams: VOLUNTEER_0 calls checkIn (pre-registered pool), VOLUNTEER_1 calls manualCheckIn (walk-in pool)."
        },
        {
          "allocate_account": "$VARIABLE:VOLUNTEER_1"
        },
        {
          "comment": "Deploy the festival-level AttendancePOAP. DEPLOYER retains factory rights \u2014 only it can authorise minters on this collection.",
          "instance": "FestivalPoap",
          "method": "#deployer",
          "caller": "$VARIABLE:DEPLOYER",
          "calldata": [
            "$VARIABLE:DEPLOYER"
          ]
        },
        {
          "comment": "Deploy the session-level AttendancePOAP. Factory rights are handed to Festival in the next step so each new FestivalSession can be authorised as a session-POAP minter at createSession time.",
          "instance": "SessionPoap",
          "method": "#deployer",
          "caller": "$VARIABLE:DEPLOYER",
          "calldata": [
            "$VARIABLE:DEPLOYER"
          ]
        },
        {
          "comment": "Deploy Festival with sessionsEnabled=true.",
          "instance": "Festival",
          "method": "#deployer",
          "caller": "$VARIABLE:DEPLOYER",
          "calldata": [
            "$VARIABLE:DEPLOYER",
            "FestivalPoap.address",
            "SessionPoap.address",
            "1"
          ]
        },
        {
          "comment": "Authorise Festival on the festival POAP. MUST come before setup() because setup() calls setVerificationDeadline which is onlyAuthorizedMinter.",
          "instance": "FestivalPoap",
          "method": "authorizeMinter",
          "caller": "$VARIABLE:DEPLOYER",
          "calldata": [
            "Festival.address"
          ]
        },
        {
          "comment": "Transfer factory rights on the session POAP to Festival.",
          "instance": "SessionPoap",
          "method": "transferFactory",
          "caller": "$VARIABLE:DEPLOYER",
          "calldata": [
            "Festival.address"
          ]
        },
        {
          "comment": "Festival.setup: window 2000000000..2002592000 (30 days, May 2033), verificationWindow=604800s (7 days post-event), capacity=5000.",
          "instance": "Festival",
          "method": "setup",
          "caller": "$VARIABLE:DEPLOYER",
          "calldata": [
            "0xf9c2171700000000000000000000000000000000000000000000000000000000",
            "2000000000",
            "2002592000",
            "604800",
            "5000"
          ]
        },
        {
          "comment": "Grant VOLUNTEER_ROLE to two volunteer accounts so the door-side phase has two independent nonce streams (checkIn vs manualCheckIn).",
          "instance": "Festival",
          "method": "grantRole",
          "caller": "$VARIABLE:DEPLOYER",
          "calldata": [
            "0xf7f0fdec05d2d68a3ca32c78a26a4236722632f1d98fdee081484acf844fc7dc",
            "$VARIABLE:VOLUNTEER_0"
          ]
        },
        {
          "comment": null,
          "instance": "Festival",
          "method": "grantRole",
          "caller": "$VARIABLE:DEPLOYER",
          "calldata": [
            "0xf7f0fdec05d2d68a3ca32c78a26a4236722632f1d98fdee081484acf844fc7dc",
            "$VARIABLE:VOLUNTEER_1"
          ]
        },
        {
          "comment": "Register spam: outer 2 \u00d7 inner 2 = 4 pre-attendees. start_watcher: true so benchmark metrics begin at the start of this phase.",
          "repeat": 2,
          "capture_index": "$VARIABLE:K",
          "consolidate_state": true,
          "steps": [
            {
              "comment": "Inner repeat: 2 pre-attendees per outer iter. Each iter allocates PRE_ATTENDEE_K_J via $VARIABLE: composition and that attendee submits register() themselves.",
              "repeat": 2,
              "capture_index": "$VARIABLE:J",
              "consolidate_state": true,
              "steps": [
                {
                  "allocate_account": "$VARIABLE:PRE_ATTENDEE_$VARIABLE:K_$VARIABLE:J"
                },
                {
                  "comment": null,
                  "instance": "Festival",
                  "method": "register",
                  "caller": "$VARIABLE:PRE_ATTENDEE_$VARIABLE:K_$VARIABLE:J",
                  "calldata": []
                }
              ]
            }
          ],
          "start_watcher": true
        },
        {
          "comment": "Combined door spam: outer 2 \u00d7 inner 2 checkIns (VOLUNTEER_0) plus 2 manualCheckIns (VOLUNTEER_1). After this phase, PRE_ATTENDEE_K_J_POAP and NEW_ATTENDEE_K_POAP are visible in parent scope for the event-day phase.",
          "repeat": 2,
          "capture_index": "$VARIABLE:K",
          "consolidate_state": true,
          "steps": [
            {
              "allocate_account": "$VARIABLE:NEW_ATTENDEE_$VARIABLE:K"
            },
            {
              "comment": "Inner repeat: 2 checkIns per outer iter (VOLUNTEER_0). Captures the returned POAP id into PRE_ATTENDEE_K_J_POAP.",
              "repeat": 2,
              "capture_index": "$VARIABLE:J",
              "consolidate_state": true,
              "steps": [
                {
                  "comment": null,
                  "instance": "Festival",
                  "method": "checkIn",
                  "caller": "$VARIABLE:VOLUNTEER_0",
                  "calldata": [
                    "$VARIABLE:PRE_ATTENDEE_$VARIABLE:K_$VARIABLE:J"
                  ],
                  "variable_assignments": {
                    "return_data": [
                      "PRE_ATTENDEE_$VARIABLE:K_$VARIABLE:J_POAP"
                    ]
                  }
                }
              ]
            },
            {
              "comment": null,
              "instance": "Festival",
              "method": "manualCheckIn",
              "caller": "$VARIABLE:VOLUNTEER_1",
              "calldata": [
                "$VARIABLE:NEW_ATTENDEE_$VARIABLE:K"
              ],
              "variable_assignments": {
                "return_data": [
                  "NEW_ATTENDEE_$VARIABLE:K_POAP"
                ]
              }
            }
          ]
        },
        {
          "comment": "Event-day for the PRE pool: outer 2 \u00d7 inner 2 \u00d7 innermost 2. 4 createSessions and 8 cross-pool verifies (PRE verifies NEW). Each (verifier, target) pair is unique since the verifier varies per (K, J) iter.",
          "repeat": 2,
          "capture_index": "$VARIABLE:K",
          "steps": [
            {
              "comment": "Inner repeat: createSession + 2 verifies per (K, J) pre-attendee.",
              "repeat": 2,
              "capture_index": "$VARIABLE:J",
              "steps": [
                {
                  "comment": null,
                  "instance": "Festival",
                  "method": "createSession",
                  "caller": "$VARIABLE:PRE_ATTENDEE_$VARIABLE:K_$VARIABLE:J",
                  "calldata": [
                    "0x5e55101100000000000000000000000000000000000000000000000000000000",
                    "$VARIABLE:K $VARIABLE:K 30 / 30 * - 86400 * 2000000000 +",
                    "$VARIABLE:K $VARIABLE:K 30 / 30 * - 86400 * 2000000000 + 7200 +",
                    "0",
                    "$VARIABLE:PRE_ATTENDEE_$VARIABLE:K_$VARIABLE:J_POAP"
                  ]
                },
                {
                  "comment": "Innermost repeat: 2 verifies per (K, J) pre-attendee. Each iter targets a different NEW_M_POAP (M = innermost capture).",
                  "repeat": 2,
                  "capture_index": "$VARIABLE:M",
                  "steps": [
                    {
                      "comment": null,
                      "instance": "FestivalPoap",
                      "method": "verify",
                      "caller": "$VARIABLE:PRE_ATTENDEE_$VARIABLE:K_$VARIABLE:J",
                      "calldata": [
                        "$VARIABLE:PRE_ATTENDEE_$VARIABLE:K_$VARIABLE:J_POAP",
                        "$VARIABLE:NEW_ATTENDEE_$VARIABLE:M_POAP"
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "comment": "Event-day for the NEW pool: outer 2 \u00d7 innermost 2. 2 createSessions and 4 cross-pool verifies (NEW verifies PRE).",
          "repeat": 2,
          "capture_index": "$VARIABLE:K",
          "steps": [
            {
              "comment": null,
              "instance": "Festival",
              "method": "createSession",
              "caller": "$VARIABLE:NEW_ATTENDEE_$VARIABLE:K",
              "calldata": [
                "0x5e55101100000000000000000000000000000000000000000000000000000000",
                "$VARIABLE:K $VARIABLE:K 30 / 30 * - 86400 * 2000000000 +",
                "$VARIABLE:K $VARIABLE:K 30 / 30 * - 86400 * 2000000000 + 7200 +",
                "0",
                "$VARIABLE:NEW_ATTENDEE_$VARIABLE:K_POAP"
              ]
            },
            {
              "comment": "Innermost repeat: 2 verifies per NEW_K walk-in. Each iter targets a different PRE_M_0_POAP (M = innermost capture, J pinned to literal 0).",
              "repeat": 2,
              "capture_index": "$VARIABLE:M",
              "steps": [
                {
                  "comment": null,
                  "instance": "FestivalPoap",
                  "method": "verify",
                  "caller": "$VARIABLE:NEW_ATTENDEE_$VARIABLE:K",
                  "calldata": [
                    "$VARIABLE:NEW_ATTENDEE_$VARIABLE:K_POAP",
                    "$VARIABLE:PRE_ATTENDEE_$VARIABLE:M_0_POAP"
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "contracts": {
    "Festival": "Festival.sol:Festival",
    "FestivalSession": "Festival.sol:FestivalSession",
    "FestivalPoap": "AttendancePOAP.sol:AttendancePOAP",
    "SessionPoap": "AttendancePOAP.sol:AttendancePOAP"
  }
}
