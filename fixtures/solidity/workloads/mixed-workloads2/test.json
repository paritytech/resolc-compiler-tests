{
  "$schema": "../../../../schema.json",
  "modes": [
    "Y Mz S+",
    "Y Ms S+",
    "Y Mz S-",
    "Y Ms S-"
  ],
  "cases": [
    {
      "name": "Mixed Workloads 2 - Code Hash Diversity",
      "comment": "Benchmarks proof size impact of 200 ERC20 tokens with different code hashes. Each token is a separate contract (V_0..V_199) with a unique variant() return value baked into the bytecode. Per iteration: each token mints to a fresh account which then transfers to a random address.",
      "inputs": [
        {
          "comment": "This is the main repeat step which publishes all of the contracts to the chain for us. Since we have 200 distinct contracts, publishing them one by one isn't really an option for us.",
          "repeat": 200,
          "await_transaction_inclusion": true,
          "capture_index": "$VARIABLE:I",
          "consolidate_state": true,
          "steps": [
            {
              "comment": "Each deployment of the contract uses a different deployer. This allows us to get rid of any kind of nonce contention we might encounter",
              "allocate_account": "$VARIABLE:DEPLOYER_ACCOUNT"
            },
            {
              "comment": "Deploy ERC20 variant",
              "instance": "$INSTANCE:$VARIABLE:I",
              "method": "#deployer",
              "caller": "$VARIABLE:DEPLOYER_ACCOUNT"
            }
          ]
        },
        {
          "comment": "This is the primary workload that we're benchmarking. In the workload we mint tokens into various different accounts. The key thing is to measure how the proof size impacts the TPS and therefore sending tokens won't be very useful here. We want to see if having a lot of contracts in the mempool leads to a different bottleneck being observed in the benchmarks.",
          "repeat": 200,
          "capture_index": "$VARIABLE:I",
          "steps": [
            {
              "comment": "Each ERC20 gets 1000 mint transactions to it",
              "repeat": 1000,
              "steps": [
                {
                  "allocate_account": "$VARIABLE:MINTER"
                },
                {
                  "comment": "Mint tokens on ERC20",
                  "instance": "$INSTANCE:$VARIABLE:I",
                  "method": "mint",
                  "caller": "$VARIABLE:MINTER",
                  "calldata": [
                    "$VARIABLE:MINTER",
                    "10000000000000000000000000"
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
